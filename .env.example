# MongoDB (required for auth)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?appName=Cluster0
# Optional: direct URI if SRV/DNS fails locally (from Atlas → Connect → Drivers)
# MONGODB_URI_STANDARD=mongodb://USER:PASSWORD@host1:27017,host2:27017,host3:27017/?ssl=true&authSource=admin
MONGODB_DB_NAME="artisan_haven"

# Auth (required)
# Generate with: openssl rand -base64 32
AUTH_SECRET="generate-a-long-random-string-here"
ADMIN_PASSWORD="Admin@123"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email — magic link login (optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-gmail-app-password"
SMTP_FROM="Artisan Haven <your-email@gmail.com>"

# Prisma / PostgreSQL (optional)
DATABASE_URL="postgresql://user:password@localhost:5432/artisan_haven"

# Stripe (optional)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# OpenAI (optional)
OPENAI_API_KEY=

# Cloudinary (optional)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
